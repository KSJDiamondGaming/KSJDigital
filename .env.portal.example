# KSJ Digital Portal API
# Copy this file to .env.portal on the VPS and fill in the real token.

# GitHub fine-grained token with contents read/write access for this repository.
GITHUB_TOKEN=replace_with_real_github_token
GITHUB_REPO=KSJHub/KSJDigital
GITHUB_BRANCH=main

# API server port. Nginx should proxy /api/portal/ to this port.
PORTAL_API_PORT=4174

# Optional. Use your real domain in production.
PORTAL_ALLOWED_ORIGIN=https://ksjdigital.co.uk

# Optional frontend setting when API is on another origin.
# If Nginx proxies /api/portal on the same domain, leave this empty in the frontend env.
VITE_PORTAL_API_BASE_URL=
